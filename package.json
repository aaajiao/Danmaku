{
  "name": "danmaku",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun tools/serve.ts",
    "make:v4-content": "bun tools/make-v4-content.ts",
    "make:v4-pack": "bun tools/make-v4-pack.ts",
    "make:v4-ui": "bun tools/make-v4-ui.ts",
    "make:pwa-icons": "bun tools/make-pwa-icons.ts",
    "measure:audio": "bun tools/measure-audio.ts",
    "test:visual": "PORT=3006 bun ./test/visual/layer-order.html",
    "test:assets": "PORT=3007 bun ./test/visual/asset-loading.html",
    "test:density": "PORT=3008 bun ./test/visual/density.html",
    "test:scenes": "PORT=3009 bun ./test/visual/scenes-compare.html",
    "build": "bun tools/clean-dist.ts && bun build ./index.html --outdir=dist --production && bun tools/copy-packs.ts && bun tools/build-pwa.ts",
