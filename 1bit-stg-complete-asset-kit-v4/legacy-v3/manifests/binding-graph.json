{
  "schemaVersion": "3.0.0",
  "description": "One-way, idempotent gameplay-to-visual binding graph. Gameplay state never depends on a clip, effect, alpha value or render callback.",
  "policy": {
    "dispatchDirection": "gameplay-event-to-visual-only",
    "authoritativeKinds": ["gameplay-event"],
    "terminalKinds": ["clip", "effect"],
    "forbidVisualToGameplayEdges": true,
    "requireAcyclic": true,
    "duplicateDispatch": "ignore-after-first-successful-claim",
    "dedupeKeyTemplates": {
      "perEvent": "edgeId:instanceId:generation:occurrenceId",
      "perLoop": "edgeId:instanceId:generation:loopIndex",
      "perStateEntry": "edgeId:instanceId:cycleId:state:stateEntryOrdinal",
      "perInstance": "edgeId:instanceId"
    }
  },
  "nodes": [
    {"id":"event:player.focus","kind":"gameplay-event","eventId":"player.focus.begin"},
    {"id":"event:player.hit","kind":"gameplay-event","eventId":"player.damage.commit"},
    {"id":"event:player.death","kind":"gameplay-event","eventId":"player.death.commit"},
    {"id":"event:player.respawn","kind":"gameplay-event","eventId":"player.respawn.place"},
    {"id":"event:player.override","kind":"gameplay-event","eventId":"player.override.begin"},
    {"id":"event:cross-run.scar-write","kind":"gameplay-event","eventId":"cross_run.scar.write.commit"},
    {"id":"event:projectile.lifecycle","kind":"gameplay-event","eventId":"projectile.lifecycle.begin"},
    {"id":"event:projectile.cancel","kind":"gameplay-event","eventId":"projectile.cancel.commit"},
    {"id":"event:projectile.cancel-residue","kind":"gameplay-event","eventId":"projectile.cancel.residue.begin"},
    {"id":"event:laser.telegraph","kind":"gameplay-event","eventId":"laser.telegraph.begin"},
    {"id":"event:laser.grow","kind":"gameplay-event","eventId":"laser.grow.begin"},
    {"id":"event:laser.live","kind":"gameplay-event","eventId":"laser.live.begin"},
    {"id":"event:laser.shutdown","kind":"gameplay-event","eventId":"laser.shutdown.begin"},
    {"id":"event:laser.residue","kind":"gameplay-event","eventId":"laser.residue.begin"},
    {"id":"event:room.transition","kind":"gameplay-event","eventId":"room.transition.begin"},
    {"id":"event:boss.phase.swap","kind":"gameplay-event","eventId":"boss.phase.swap"},
    {"id":"event:cross-run.snapshot","kind":"gameplay-event","eventId":"cross_run.snapshot.begin"},

    {"id":"clip:player.focus","kind":"clip","ref":"player.focus"},
    {"id":"clip:player.causality","kind":"clip","ref":"player.causality.damage_to_trace"},
    {"id":"clip:player.respawn","kind":"clip","ref":"player.return_with_history"},
    {"id":"clip:player.override","kind":"clip","ref":"system.override.directional"},
    {"id":"clip:memory.directional-write","kind":"clip","ref":"memory.directional_write"},
    {"id":"clip:projectile.lifecycle","kind":"clip","ref":"bullet.lifecycle"},
    {"id":"clip:projectile.cancel","kind":"clip","ref":"bullet.cancel"},
    {"id":"clip:laser.lifecycle","kind":"clip","ref":"boss.laser.lifecycle"},
    {"id":"clip:cross-run.snapshot","kind":"clip","ref":"state.snapshot_handoff"},

    {"id":"effect:damage.flash","kind":"effect","ref":"sprite.damage_flash"},
    {"id":"effect:bullet.cancel","kind":"effect","ref":"bullet.cancel_dither"},
    {"id":"effect:laser.warning","kind":"effect","ref":"laser.warning_pulse"},
    {"id":"effect:laser.grow","kind":"effect","ref":"laser.grow"},
    {"id":"effect:laser.live","kind":"effect","ref":"laser.body_scroll"},
    {"id":"effect:laser.shutdown","kind":"effect","ref":"laser.shutdown"},
    {"id":"effect:room.transition","kind":"effect","ref":"room.transition_mask"},
    {"id":"effect:boss.phase.swap","kind":"effect","ref":"boss.phase_swap"}
  ],
  "edges": [
    {"id":"bind.player.focus.clip","from":"event:player.focus","to":"clip:player.focus","scope":"perEvent"},
    {"id":"bind.player.hit.clip","from":"event:player.hit","to":"clip:player.causality","scope":"perEvent"},
    {"id":"bind.player.hit.flash","from":"event:player.hit","to":"effect:damage.flash","scope":"perEvent"},
    {"id":"bind.player.death.clip","from":"event:player.death","to":"clip:player.causality","scope":"perEvent"},
    {"id":"bind.player.respawn.clip","from":"event:player.respawn","to":"clip:player.respawn","scope":"perEvent"},
    {"id":"bind.player.override.clip","from":"event:player.override","to":"clip:player.override","scope":"perEvent"},
    {"id":"bind.cross-run.scar-write.clip","from":"event:cross-run.scar-write","to":"clip:memory.directional-write","scope":"perEvent"},
    {"id":"bind.projectile.lifecycle.clip","from":"event:projectile.lifecycle","to":"clip:projectile.lifecycle","scope":"perEvent"},
    {"id":"bind.projectile.cancel.clip","from":"event:projectile.cancel","to":"clip:projectile.cancel","scope":"perEvent"},
    {"id":"bind.projectile.cancel.effect","from":"event:projectile.cancel","to":"effect:bullet.cancel","scope":"perEvent"},
    {"id":"bind.projectile.cancel.residue","from":"event:projectile.cancel-residue","to":"clip:projectile.lifecycle","scope":"perEvent","segment":{"fromFrameId":"bullet.afterimage","toFrameId":"bullet.clear"}},
    {"id":"bind.laser.telegraph.clip","from":"event:laser.telegraph","to":"clip:laser.lifecycle","scope":"perStateEntry"},
    {"id":"bind.laser.telegraph.effect","from":"event:laser.telegraph","to":"effect:laser.warning","scope":"perStateEntry"},
    {"id":"bind.laser.grow.effect","from":"event:laser.grow","to":"effect:laser.grow","scope":"perStateEntry"},
    {"id":"bind.laser.live.effect","from":"event:laser.live","to":"effect:laser.live","scope":"perStateEntry"},
    {"id":"bind.laser.shutdown.effect","from":"event:laser.shutdown","to":"effect:laser.shutdown","scope":"perStateEntry"},
    {"id":"bind.laser.residue.effect","from":"event:laser.residue","to":"effect:laser.shutdown","scope":"perStateEntry"},
    {"id":"bind.room.transition.effect","from":"event:room.transition","to":"effect:room.transition","scope":"perEvent"},
    {"id":"bind.boss.phase.effect","from":"event:boss.phase.swap","to":"effect:boss.phase.swap","scope":"perEvent"},
    {"id":"bind.cross-run.snapshot.clip","from":"event:cross-run.snapshot","to":"clip:cross-run.snapshot","scope":"perEvent"}
  ]
}
