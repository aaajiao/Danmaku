{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noEmitOnError": true,
    "outDir": "build",
    "rootDir": ".",
    "lib": ["ES2022", "DOM"],
    "skipLibCheck": true
  },
  "include": ["*.ts"],
  "exclude": ["build"]
}
