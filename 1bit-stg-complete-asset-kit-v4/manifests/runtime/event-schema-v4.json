{
  "schemaVersion": "4.0.0",
  "id": "1bit.event-schema.v4",
  "envelope": {
    "authority": "gameplay",
    "required": ["id", "authority", "simulationTimeMs", "sequence", "occurrenceKey", "payload"],
    "types": {
      "id": "catalog-event-id",
      "authority": "literal:gameplay",
      "simulationTimeMs": "finite-number>=0",
      "sequence": "integer>=0",
      "occurrenceKey": "non-empty-unique-string",
      "payload": "json-object"
    },
    "ordering": "simulationTimeMs-then-sequence",
    "duplicateOccurrencePolicy": "throw"
  },
  "events": [
    {"id":"player.collision.off","domain":"player","criticality":"critical","requiredPayload":["owner","reason"]},
    {"id":"player.collision.on","domain":"player","criticality":"critical","requiredPayload":["owner","reason"]},
    {"id":"player.damage.commit","domain":"player","criticality":"critical","requiredPayload":["amount","healthAfter","sourceId","branch"]},
    {"id":"player.invulnerability.begin","domain":"player","criticality":"support","requiredPayload":["reason"]},
    {"id":"player.invulnerability.end","domain":"player","criticality":"support","requiredPayload":["reason"]},
    {"id":"player.death.commit","domain":"player","criticality":"critical","requiredPayload":["sourceId","branch"]},
    {"id":"player.life.consume","domain":"player","criticality":"critical","requiredPayload":["livesAfter"]},
    {"id":"player.respawn.place","domain":"player","criticality":"critical","requiredPayload":["health"]},
    {"id":"player.respawn.complete","domain":"player","criticality":"critical","requiredPayload":[]},
    {"id":"player.input.off","domain":"player","criticality":"critical","requiredPayload":["reason"]},
    {"id":"run.end.commit","domain":"run","criticality":"critical","requiredPayload":["reason"]},

    {"id":"projectile.spawn.commit","domain":"projectile","criticality":"critical","requiredPayload":["instanceId","generation","archetypeId"]},
    {"id":"projectile.arm.begin","domain":"projectile","criticality":"critical","requiredPayload":["instanceId","generation","readyAtMs"]},
    {"id":"projectile.armed","domain":"projectile","criticality":"critical","requiredPayload":["instanceId","generation"]},
    {"id":"projectile.flight.begin","domain":"projectile","criticality":"critical","requiredPayload":["instanceId","generation","ownership"]},
    {"id":"projectile.collision.on","domain":"projectile","criticality":"critical","requiredPayload":["instanceId","generation"]},
    {"id":"projectile.collision.off","domain":"projectile","criticality":"critical","requiredPayload":["instanceId","generation","reason"]},
    {"id":"projectile.impact.commit","domain":"projectile","criticality":"critical","requiredPayload":["instanceId","generation","targetId"]},
    {"id":"projectile.cancel.commit","domain":"projectile","criticality":"critical","requiredPayload":["instanceId","generation","reason"]},
    {"id":"projectile.residue.begin","domain":"projectile","criticality":"support","requiredPayload":["instanceId","generation","cause","removeAtMs"]},
    {"id":"projectile.residue.remove","domain":"projectile","criticality":"support","requiredPayload":["instanceId","generation","cause"]},
    {"id":"projectile.lifecycle.complete","domain":"projectile","criticality":"support","requiredPayload":["instanceId","generation","cause"]},
    {"id":"projectile.graze.commit","domain":"projectile","criticality":"critical","requiredPayload":["projectileId","projectileGeneration","playerId","evidence"]},
    {"id":"evidence.gain.commit","domain":"evidence","criticality":"critical","requiredPayload":["amount","total","sourceKey"]},
    {"id":"evidence.consume.commit","domain":"evidence","criticality":"critical","requiredPayload":["amount","total","purposeKey"]},

    {"id":"gaze.acquire.begin","domain":"gaze","criticality":"support","requiredPayload":["cycle","clampAtMs"]},
    {"id":"gaze.acquire.cancel","domain":"gaze","criticality":"support","requiredPayload":["cycle"]},
    {"id":"gaze.clamp.commit","domain":"gaze","criticality":"critical","requiredPayload":["cycle","forcedIntensity"]},
    {"id":"gaze.release.begin","domain":"gaze","criticality":"support","requiredPayload":["cycle","releaseAtMs"]},
    {"id":"gaze.release.cancel","domain":"gaze","criticality":"support","requiredPayload":["cycle","releaseAttempt"]},
    {"id":"gaze.clamp.release","domain":"gaze","criticality":"critical","requiredPayload":["cycle","releaseAttempt"]},
    {"id":"flower.intensity.commit","domain":"flower","criticality":"critical","requiredPayload":["source","targetIntensity"]},

    {"id":"player.override.charge.begin","domain":"override","criticality":"critical","requiredPayload":["cycle","roomId","commitAtMs","evidenceCost"]},
    {"id":"player.override.charge.cancel","domain":"override","criticality":"support","requiredPayload":["cycle"]},
    {"id":"player.override.denied","domain":"override","criticality":"support","requiredPayload":["cycle","reason"]},
    {"id":"player.override.commit","domain":"override","criticality":"critical","requiredPayload":["cycle","roomId","mode"]},
    {"id":"player.override.local_void.open","domain":"override","criticality":"critical","requiredPayload":["cycle","originX","originY","directionX","directionY","radius","halfAngleDegrees"]},
    {"id":"player.override.local_void.close","domain":"override","criticality":"critical","requiredPayload":["cycle"]},
    {"id":"cross_run.scar.write.commit","domain":"cross-run","criticality":"critical","requiredPayload":["cycle","scarType","roomId","x","y","directionX","directionY"]},
    {"id":"player.override.material_sediment.begin","domain":"override","criticality":"support","requiredPayload":["cycle","scarType"]},
    {"id":"player.override.cooldown.begin","domain":"override","criticality":"support","requiredPayload":["cycle"]},
    {"id":"player.override.ready","domain":"override","criticality":"support","requiredPayload":["cycle"]},

    {"id":"boss.encounter.begin","domain":"boss","criticality":"critical","requiredPayload":["bossId","generation","phaseCount"]},
    {"id":"boss.phase.enter","domain":"boss","criticality":"critical","requiredPayload":["bossId","generation","phaseId","phaseIndex"]},
    {"id":"boss.phase.exit","domain":"boss","criticality":"critical","requiredPayload":["bossId","generation","phaseId","cause"]},
    {"id":"boss.phase.swap","domain":"boss","criticality":"critical","requiredPayload":["bossId","generation","fromPhaseId","toPhaseId"]},
    {"id":"boss.phase.attack_plan.commit","domain":"boss","criticality":"critical","requiredPayload":["bossId","generation","phaseId","attackPlanId"]},
    {"id":"boss.encounter.resolve","domain":"boss","criticality":"critical","requiredPayload":["bossId","generation","outcome","finalPhaseId"]},

    {"id":"weather.omen.begin","domain":"weather","criticality":"critical","requiredPayload":["weather","cycle","activeAtMs"]},
    {"id":"weather.active.begin","domain":"weather","criticality":"critical","requiredPayload":["weather","cycle"]},
    {"id":"weather.aftermath.begin","domain":"weather","criticality":"support","requiredPayload":["weather","cycle"]},
    {"id":"weather.cooldown.begin","domain":"weather","criticality":"support","requiredPayload":["weather","cycle"]},
    {"id":"weather.complete","domain":"weather","criticality":"support","requiredPayload":["weather","cycle"]},

    {"id":"snapshot.begin","domain":"snapshot","criticality":"critical","requiredPayload":["runId"]},
    {"id":"snapshot.serialize.commit","domain":"snapshot","criticality":"critical","requiredPayload":["runId","snapshotHash","deterministicSeed","routeDigest","routeDurationMs","materialCounts"]},
    {"id":"snapshot.present.begin","domain":"snapshot","criticality":"support","requiredPayload":["runId","snapshotHash"]},
    {"id":"snapshot.complete","domain":"snapshot","criticality":"support","requiredPayload":["runId"]},
    {"id":"cross_run.record.persist.commit","domain":"cross-run","criticality":"critical","requiredPayload":["runId","snapshotHash","deterministicSeed","routeDigest","routeDurationMs","materialCounts"]},
    {"id":"cross_run.restore.begin","domain":"cross-run","criticality":"critical","requiredPayload":["fromRunId","nextRunId","routeDigest","routeDurationMs"]},
    {"id":"overrideScar.rehydrate","domain":"cross-run","criticality":"critical","requiredPayload":["fromRunId","nextRunId","recordType","count","records"]},
    {"id":"deathTrace.rehydrate","domain":"cross-run","criticality":"critical","requiredPayload":["fromRunId","nextRunId","recordType","count","records"]},
    {"id":"burnIn.rehydrate","domain":"cross-run","criticality":"critical","requiredPayload":["fromRunId","nextRunId","recordType","count","records"]},
    {"id":"ghost.replay.begin","domain":"cross-run","criticality":"critical","requiredPayload":["fromRunId","nextRunId","routeDigest","routeDurationMs","pointCount","routePoints","timeScale","collisionClass","rewardClass","emitterClass"]},
    {"id":"ghost.replay.complete","domain":"cross-run","criticality":"critical","requiredPayload":["fromRunId","nextRunId","routeDigest","routeDurationMs","finalPoint","burnAfterRead"]},
    {"id":"ghost.residue.write","domain":"cross-run","criticality":"critical","requiredPayload":["fromRunId","nextRunId","recordType","residueId","sourceRouteDigest","createdAfterReplay","persistenceRuns","position","priorGhostResidueCount"]},
    {"id":"witness.turn","domain":"cross-run","criticality":"critical","requiredPayload":["fromRunId","nextRunId","evaluatedAfterGhostResidue","overrideScarIds","ghostEndpoint","priority"]},
    {"id":"returnInput","domain":"cross-run","criticality":"critical","requiredPayload":["fromRunId","nextRunId","inputState","routeDurationMs"]},
    {"id":"cross_run.restore.complete","domain":"cross-run","criticality":"critical","requiredPayload":["fromRunId","nextRunId","routeDigest","routeDurationMs"]},

    {"id":"room.transition.begin","domain":"room","criticality":"critical","requiredPayload":["generation","fromRoom","toRoom"]},
    {"id":"room.transition.world_swap.commit","domain":"room","criticality":"critical","requiredPayload":["generation","fromRoom","toRoom"]},
    {"id":"room.transition.room_ready","domain":"room","criticality":"critical","requiredPayload":["generation","room"]},
    {"id":"room.transition.complete","domain":"room","criticality":"support","requiredPayload":["generation","room"]}
  ]
}
