{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "$id": "projectile-lifecycle-v4.schema.json",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "authority",
    "states",
    "invariants",
    "grazeEvidence",
    "collision",
    "poolBudgets",
    "cancelConsequences"
  ],
  "properties": {
    "states": {
      "type": "array",
      "minItems": 7,
      "maxItems": 7
    }
  }
}
