{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "$id": "enemies-v4.schema.json",
  "type": "object",
  "required": [
    "schemaVersion",
    "mechanicalRoleCount",
    "enemies"
  ],
  "properties": {
    "mechanicalRoleCount": {
      "type": "integer",
      "minimum": 8
    },
    "enemies": {
      "type": "array",
      "minItems": 16,
      "maxItems": 16,
      "items": {
        "type": "object",
        "required": [
          "id",
          "role",
          "entry",
          "movement",
          "formation",
          "cadence",
          "exit",
          "telegraph",
          "materialResidue",
          "collision"
        ]
      }
    }
  }
}
