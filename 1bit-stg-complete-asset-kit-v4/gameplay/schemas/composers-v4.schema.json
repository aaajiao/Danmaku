{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "$id": "composers-v4.schema.json",
  "type": "object",
  "required": [
    "schemaVersion",
    "composers"
  ],
  "properties": {
    "composers": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "required": [
          "id",
          "room",
          "algorithm",
          "patternPool",
          "behaviorMetricWeights",
          "intensityTiers",
          "constraints",
          "materialLedger"
        ]
      }
    }
  }
}
