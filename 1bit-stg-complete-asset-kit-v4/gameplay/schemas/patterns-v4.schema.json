{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "$id": "patterns-v4.schema.json",
  "type": "object",
  "required": [
    "schemaVersion",
    "patterns"
  ],
  "properties": {
    "schemaVersion": {
      "const": "4.0.0"
    },
    "patterns": {
      "type": "array",
      "minItems": 48,
      "maxItems": 48,
      "items": {
        "type": "object",
        "required": [
          "id",
          "category",
          "room",
          "durationMs",
          "clock",
          "timeline",
          "emitters",
          "safeGap",
          "warning",
          "cancel",
          "residue",
          "difficulty",
          "seed"
        ],
        "properties": {
          "emitters": {
            "type": "array",
            "minItems": 1
          },
          "timeline": {
            "type": "array",
            "minItems": 7
          }
        }
      }
    }
  }
}
